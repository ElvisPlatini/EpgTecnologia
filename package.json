{
  "name": "epg-tecnologia-cloudflare",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "site:dev": "wrangler pages dev --config site/wrangler.jsonc",
    "site:deploy": "wrangler pages deploy --config site/wrangler.jsonc",
    "worker:dev": "wrangler dev",
    "worker:deploy": "wrangler deploy",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "latest",
    "typescript": "^5.8.3",
    "wrangler": "^4.0.0"
  }
}
